{
  "name": "@felinestatemachine/test-todo",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./app.ts": "./app.ts"
  },
  "imports": {
    "@felinestatemachine/denomerge": "../src/index.ts",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@automerge/automerge-repo": "npm:@automerge/automerge-repo@^2.5.5",
    "@automerge/automerge-repo-storage-indexeddb": "npm:@automerge/automerge-repo-storage-indexeddb@^2.5.5",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.2.1",
    "@logtape/pretty": "jsr:@logtape/pretty@^2.2.1"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run build.ts",
    "start": "deno run --unstable-kv --allow-net --allow-env --allow-read --allow-write main.ts",
    "dev": "deno run --unstable-kv --allow-net --allow-env --allow-read --allow-write --watch main.ts"
  },
  "deploy": {
    "org": "felinestatemachine",
    "app": "test-todo",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./main.ts"
    }
  }
}
