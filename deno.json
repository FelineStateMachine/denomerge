{
  "name": "@felinestatemachine/denomerge",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth/mod.ts",
    "./crypto": "./src/crypto/mod.ts",
    "./kv": "./src/kv/mod.ts",
    "./storage": "./src/storage/mod.ts",
    "./sync": "./src/sync/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@automerge/automerge-repo": "npm:@automerge/automerge-repo@^2.5.5",
    "@automerge/automerge-repo-storage-indexeddb": "npm:@automerge/automerge-repo-storage-indexeddb@^2.5.5"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno test --allow-read --allow-net --allow-env",
    "test": "deno test --allow-read --allow-net --allow-env",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "deploy": {
    "org": "felinestatemachine",
    "app": "test-todo",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./example/main.ts",
      "cwd": "./example"
    }
  }
}
